# Cockpit — Environment Configuration
# Copy to /etc/cockpit/cockpit.env, chmod 600, root-owned.

# ── Database ────────────────────────────────────────────────────────────
COCKPIT_DB_PATH=/var/lib/cockpit/cockpit.db

# ── WHM API ─────────────────────────────────────────────────────────────
# API token generated in WHM → API Tokens → Generate
COCKPIT_WHM_HOST=localhost
COCKPIT_WHM_PORT=2087
COCKPIT_WHM_TOKEN=your_whm_api_token_here
COCKPIT_WHM_VERIFY_SSL=false

# ── Dashboard ───────────────────────────────────────────────────────────
# Binds to localhost; Tailscale funnel or reverse proxy for external access
COCKPIT_DASHBOARD_HOST=127.0.0.1
COCKPIT_DASHBOARD_PORT=8080
COCKPIT_TAILSCALE_AUTH_ENABLED=true

# ── Client Telemetry API (Phase 2.5) ────────────────────────────────────
# Shared secret between Cockpit and Next.js server.
# Keep out of browser code — server-side calls only.
COCKPIT_CLIENT_API_KEY=generate_a_random_secret_here
COCKPIT_CLIENT_API_HOST=127.0.0.1
COCKPIT_CLIENT_API_PORT=8081

# ── OpenAI (Codex review, Phase 6) ──────────────────────────────────────
# COCKPIT_OPENAI_API_KEY=sk-...

# ── Policy ──────────────────────────────────────────────────────────────
COCKPIT_POLICY_PATH=/etc/cockpit/policy.toml

# ── Scheduling ──────────────────────────────────────────────────────────
# COCKPIT_COLLECTOR_INTERVAL_CRITICAL_LOOP=300
# COCKPIT_COLLECTOR_INTERVAL_STATS=600
# COCKPIT_COLLECTOR_INTERVAL_HTTP_HEALTH=180

# ── HTTP Health Check Tuning ────────────────────────────────────────────
# COCKPIT_HTTP_CHECK_CONCURRENCY=50
# COCKPIT_HTTP_CHECK_TIMEOUT=15
# COCKPIT_HTTP_CHECK_USER_AGENT=BluePanda-Cockpit/1.0

# ── Retention ───────────────────────────────────────────────────────────
# COCKPIT_TELEMETRY_RETENTION_DAYS=14
