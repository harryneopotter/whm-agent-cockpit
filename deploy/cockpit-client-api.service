[Unit]
Description=Cockpit Client Telemetry API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=cockpit
Group=cockpit
EnvironmentFile=/etc/cockpit/cockpit.env
ExecStart=/usr/local/bin/cockpit-client-api
Restart=always
RestartSec=5
CPUQuota=20%
MemoryMax=256M
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=full
CapabilityBoundingSet=
AmbientCapabilities=

[Install]
WantedBy=multi-user.target
